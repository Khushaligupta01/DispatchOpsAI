# ==================================================
# DispatchOps AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ==================================================

# --- Application ---
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR

# --- PostgreSQL ---
POSTGRES_USER=dispatchops
POSTGRES_PASSWORD=dispatchops_secret
POSTGRES_DB=dispatchops_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://dispatchops:dispatchops_secret@db:5432/dispatchops_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Twilio ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# --- Groq ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192

# --- Whisper ---
WHISPER_MODEL_SIZE=base      # tiny | base | small | medium | large

# --- Langfuse ---
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Audio Storage ---
AUDIO_UPLOAD_DIR=uploads
